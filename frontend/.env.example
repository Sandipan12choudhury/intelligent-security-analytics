# Copy this file to frontend/.env for local development, or set
# VITE_API_BASE_URL in your hosting platform's environment variable
# settings (Vercel/Netlify) for production.
#
# Vite bakes this value in at BUILD time, not runtime - if you change
# it, you must rebuild (npm run build) for it to take effect.

# Local development (leave as-is, or omit this file entirely - the
# app already falls back to this same value automatically):
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production example:
# VITE_API_BASE_URL=https://isap-backend.onrender.com
