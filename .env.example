# =============================================================================
# Intelligent Security Analytics Platform - Environment Variables
#
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file.
# =============================================================================

# ---- AI (already required by the existing AI Workspace feature) ----
GEMINI_API_KEY=

# ---- Auth: JWT session signing ----
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRY_HOURS=12

# ---- Auth: SMS OTP via Twilio (optional) ----
# If left blank, OTP codes print to the server console instead of
# being texted - the app still works fully, just without real SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- Auth: Email OTP via SMTP (optional) ----
# If left blank, OTP codes print to the server console instead of
# being emailed. Works out of the box with a Gmail App Password:
# Google Account -> Security -> 2-Step Verification -> App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ---- CORS ----
# Comma-separated list of frontend URLs allowed to call this backend.
# For local development, the default below is fine as-is.
# For production, add your deployed frontend URL, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
